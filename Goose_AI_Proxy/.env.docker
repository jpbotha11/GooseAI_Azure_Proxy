# =========================
# Azure OpenAI Proxy Configuration
# =========================
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_DEPLOYMENT_NAME=gpt-4.1

# =========================
# Azure AI Foundry Proxy Configuration
# =========================
AZURE_AI_API_KEY=your-azure-ai-api-key-here
AZURE_AI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_AI_API_VERSION=2024-05-01-preview
DEFAULT_AI_MODEL=gpt-5

# =========================
# Rate Limiting Configuration (Azure AI Foundry only)
# =========================
RATE_LIMIT_DELAY=0
RATE_LIMIT_RPM=0
RATE_LIMIT_TPM=0
